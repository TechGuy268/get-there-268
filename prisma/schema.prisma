generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RIDER
  DRIVER
  ADMIN
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PayMethod {
  CARD
  CASH
}

enum PayStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  password        String
  phone           String?
  role            Role           @default(RIDER)
  avatarUrl       String?
  ridesAsRider    Ride[]         @relation("RiderRides")
  ridesAsDriver   Ride[]         @relation("DriverRides")
  driverProfile   DriverProfile?
  messagesSent    Message[]
  reviewsGiven    Review[]       @relation("ReviewFrom")
  reviewsReceived Review[]       @relation("ReviewTo")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model DriverProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  licenseNumber   String
  vehicleMake     String
  vehicleModel    String
  vehiclePlate    String
  vehicleColor    String
  isOnline        Boolean  @default(false)
  isApproved      Boolean  @default(false)
  rating          Float    @default(5.0)
  totalTrips      Int      @default(0)
  currentLat      Float?
  currentLng      Float?
  updatedAt       DateTime @updatedAt
}

model Ride {
  id             String     @id @default(cuid())
  riderId        String
  rider          User       @relation("RiderRides", fields: [riderId], references: [id])
  driverId       String?
  driver         User?      @relation("DriverRides", fields: [driverId], references: [id])
  pickupAddress  String
  pickupLat      Float
  pickupLng      Float
  destAddress    String
  destLat        Float
  destLng        Float
  status         RideStatus @default(REQUESTED)
  fareEstimate   Float
  fareActual     Float?
  paymentMethod  PayMethod  @default(CASH)
  distanceKm     Float?
  durationMin    Float?
  messages       Message[]
  review         Review?
  payment        Payment?
  requestedAt    DateTime   @default(now())
  acceptedAt     DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?

  @@index([riderId])
  @@index([driverId])
  @@index([status])
}

model Message {
  id        String   @id @default(cuid())
  rideId    String
  ride      Ride     @relation(fields: [rideId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([rideId])
}

model Review {
  id         String   @id @default(cuid())
  rideId     String   @unique
  ride       Ride     @relation(fields: [rideId], references: [id])
  fromUserId String
  from       User     @relation("ReviewFrom", fields: [fromUserId], references: [id])
  toUserId   String
  to         User     @relation("ReviewTo", fields: [toUserId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Payment {
  id                    String    @id @default(cuid())
  rideId                String    @unique
  ride                  Ride      @relation(fields: [rideId], references: [id])
  amount                Float
  method                PayMethod
  status                PayStatus @default(PENDING)
  stripePaymentIntentId String?
  createdAt             DateTime  @default(now())
}

model PricingConfig {
  id              String  @id @default("default")
  baseFare        Float   @default(3.00)
  perKm           Float   @default(1.50)
  perMinute       Float   @default(0.25)
  surgeActive     Boolean @default(false)
  surgeMultiplier Float   @default(1.0)
  currency        String  @default("XCD")
}
